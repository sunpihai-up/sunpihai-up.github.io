source "https://rubygems.org"

# GitHub Pages builds the site with this gem. It pins a Jekyll version that is
# compatible with the Pages infrastructure and bundles all supported plugins
# (including jekyll-remote-theme, which this site uses). Declaring github-pages
# here avoids the "github-pages gem can't satisfy your Gemfile" build error that
# a hard-pinned `gem "jekyll", "~> 3.8.5"` produces.
gem "github-pages", group: :jekyll_plugins

# Required to run `bundle exec jekyll serve` locally on Ruby 3.0+.
gem "webrick", "~> 1.8"
